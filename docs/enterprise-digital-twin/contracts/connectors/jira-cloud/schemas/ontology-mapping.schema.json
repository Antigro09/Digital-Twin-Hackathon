{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/ontology-mapping.schema.json",
  "title": "Jira Cloud H1 Ontology Mapping Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mapping_id", "version", "provider", "object_type", "input_schema_id", "output_schema_id", "source_key", "source_revision", "ontology_type", "attributes", "relationships", "acl", "effective_time", "source_locator", "excluded_source_pointers", "canonicalization"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "mapping_id": {"const": "jira.issue.h1"},
    "version": {"const": "1.0.0"},
    "provider": {"const": "jira"},
    "object_type": {"const": "issue"},
    "input_schema_id": {"const": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/raw-envelope.schema.json"},
    "output_schema_id": {"const": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/normalized-observation.schema.json"},
    "source_key": {"$ref": "#/$defs/PointerMapping"},
    "source_revision": {"$ref": "#/$defs/PointerMapping"},
    "ontology_type": {"const": "edt.work.WorkItem"},
    "attributes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/AttributeMapping"}},
    "relationships": {"type": "array", "items": {"$ref": "#/$defs/RelationshipMapping"}},
    "acl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["behavior", "visibility_source", "principal_source", "default_classification"],
      "properties": {
        "behavior": {"const": "source_visibility_intersection"},
        "visibility_source": {"const": "project_and_issue_security"},
        "principal_source": {"const": "server_resolved_jira_permissions"},
        "default_classification": {"enum": ["confidential", "restricted"]}
      }
    },
    "effective_time": {"type": "object", "additionalProperties": false, "required": ["valid_from_pointer", "valid_to"], "properties": {"valid_from_pointer": {"const": "/payload/fields/updated"}, "valid_to": {"const": null}}},
    "source_locator": {"type": "object", "additionalProperties": false, "required": ["application_route", "provider_template"], "properties": {"application_route": {"const": "/evidence/{evidence_id}"}, "provider_template": {"const": "/browse/{key}"}}},
    "excluded_source_pointers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["/payload/fields/attachment/content", "/payload/fields/comment/body", "/payload/fields/worklog", "/payload/fields/environment"]}},
    "canonicalization": {"const": "RFC8785_UTF8_LF_SORTED_ARRAYS_WHERE_DECLARED"}
  },
  "$defs": {
    "SourcePointer": {"enum": ["/external_object_id", "/external_version", "/payload/id", "/payload/key", "/payload/fields/summary", "/payload/fields/status/name", "/payload/fields/priority/id", "/payload/fields/labels", "/payload/fields/duedate", "/payload/fields/updated", "/payload/fields/project/key", "/payload/fields/issuetype/name", "/payload/fields/issuelinks"]},
    "PointerMapping": {"type": "object", "additionalProperties": false, "required": ["source_pointer", "transform"], "properties": {"source_pointer": {"$ref": "#/$defs/SourcePointer"}, "transform": {"enum": ["identity", "jira_key", "canonical_sha256"]}}},
    "AttributeMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pointer", "predicate", "transform", "classification", "authority", "required"],
      "properties": {
        "source_pointer": {"$ref": "#/$defs/SourcePointer"},
        "predicate": {"enum": ["edt.work.summary", "edt.work.status", "edt.work.priority_id", "edt.work.labels", "edt.work.due_date", "edt.work.updated_at", "edt.work.project_key", "edt.work.issue_type"]},
        "transform": {"enum": ["identity", "lowercase", "date", "rfc3339", "sort_unique"]},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "authority": {"const": "source"},
        "required": {"type": "boolean"}
      }
    },
    "RelationshipMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pointer", "predicate", "target_transform", "classification", "confidence"],
      "properties": {
        "source_pointer": {"$ref": "#/$defs/SourcePointer"},
        "predicate": {"enum": ["edt.work.blocks", "edt.work.belongstoproject"]},
        "target_transform": {"enum": ["jira_link_targets", "jira_project_key"]},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
