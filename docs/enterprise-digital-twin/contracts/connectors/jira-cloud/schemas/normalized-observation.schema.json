{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/normalized-observation.schema.json",
  "title": "Jira Cloud H1 Normalized Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observation_id", "tenant_id", "installation_id", "provider", "source_key", "source_revision", "ontology_candidate_type", "attributes", "relationships", "source_acl", "effective_time", "source_locator", "parser_version", "mapping_id", "mapping_version", "raw_payload_sha256", "warnings", "status"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "observation_id": {"type": "string", "format": "uuid"},
    "tenant_id": {"type": "string", "format": "uuid"},
    "installation_id": {"type": "string", "format": "uuid"},
    "provider": {"const": "jira"},
    "source_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,19}-[1-9][0-9]*$"},
    "source_revision": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "ontology_candidate_type": {"const": "edt.work.WorkItem"},
    "attributes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/Attribute"}},
    "relationships": {"type": "array", "items": {"$ref": "#/$defs/Relationship"}},
    "source_acl": {"$ref": "#/$defs/SourceACL"},
    "effective_time": {"$ref": "#/$defs/Interval"},
    "source_locator": {"$ref": "#/$defs/SourceLocator"},
    "parser_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "mapping_id": {"const": "jira.issue.h1"},
    "mapping_version": {"const": "1.0.0"},
    "raw_payload_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "warnings": {"type": "array", "items": {"$ref": "#/$defs/Warning"}},
    "status": {"enum": ["active", "tombstone", "quarantined", "superseded"]}
  },
  "$defs": {
    "Attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "value", "value_type", "classification", "authority"],
      "properties": {
        "predicate": {"type": "string", "pattern": "^edt\\.[a-z0-9_.]+$"},
        "value": {},
        "value_type": {"enum": ["string", "integer", "number", "boolean", "date", "date-time", "string-array", "json"]},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "authority": {"const": "source"}
      }
    },
    "Relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "target_source_key", "classification", "confidence"],
      "properties": {
        "predicate": {"enum": ["edt.work.blocks", "edt.work.belongsToProject", "edt.work.implements"]},
        "target_source_key": {"type": "string", "minLength": 1},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "SourceACL": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acl_class", "visibility", "principal_ids", "permission_revision"],
      "properties": {
        "acl_class": {"type": "string", "minLength": 1},
        "visibility": {"enum": ["project", "issue_security", "restricted"]},
        "principal_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uuid"}},
        "permission_revision": {"type": "string", "minLength": 1}
      }
    },
    "Interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_from", "valid_to"],
      "properties": {"valid_from": {"type": "string", "format": "date-time"}, "valid_to": {"type": ["string", "null"], "format": "date-time"}}
    },
    "SourceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["application_path", "provider_path"],
      "properties": {
        "application_path": {"type": "string", "pattern": "^/evidence/[0-9a-f-]{36}$"},
        "provider_path": {"type": "string", "pattern": "^/browse/[A-Z][A-Z0-9_]{1,19}-[1-9][0-9]*$"}
      }
    },
    "Warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "source_pointer", "message"],
      "properties": {"code": {"type": "string", "pattern": "^MAP_[A-Z0-9_]+$"}, "source_pointer": {"type": "string", "pattern": "^/"}, "message": {"type": "string", "maxLength": 500}}
    }
  }
}
