{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/ontology-mapping.schema.json",
  "title": "GitHub H1 Ontology Mapping Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mapping_id", "version", "provider", "object_type", "input_schema_id", "output_schema_id", "source_key", "source_revision", "ontology_type", "attributes", "relationships", "acl", "effective_time", "source_locator", "excluded_source_pointers", "canonicalization"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "mapping_id": {"const": "github.pull-request.h1"},
    "version": {"const": "1.0.0"},
    "provider": {"const": "github"},
    "object_type": {"const": "pull_request"},
    "input_schema_id": {"const": "https://enterprise-digital-twin.example/connectors/github/1.0.0/raw-envelope.schema.json"},
    "output_schema_id": {"const": "https://enterprise-digital-twin.example/connectors/github/1.0.0/normalized-observation.schema.json"},
    "source_key": {"$ref": "#/$defs/PointerMapping"},
    "source_revision": {"$ref": "#/$defs/PointerMapping"},
    "ontology_type": {"const": "edt.engineering.PullRequest"},
    "attributes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/AttributeMapping"}},
    "relationships": {"type": "array", "items": {"$ref": "#/$defs/RelationshipMapping"}},
    "acl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["behavior", "visibility_source", "principal_source", "default_classification"],
      "properties": {
        "behavior": {"const": "source_visibility_intersection"},
        "visibility_source": {"const": "installation_repository_acl"},
        "principal_source": {"const": "server_resolved_installation_permissions"},
        "default_classification": {"enum": ["confidential", "restricted"]}
      }
    },
    "effective_time": {"type": "object", "additionalProperties": false, "required": ["valid_from_pointer", "valid_to"], "properties": {"valid_from_pointer": {"const": "/payload/updated_at"}, "valid_to": {"const": null}}},
    "source_locator": {"type": "object", "additionalProperties": false, "required": ["application_route", "provider_template"], "properties": {"application_route": {"const": "/evidence/{evidence_id}"}, "provider_template": {"const": "https://github.com/{repository}/pull/{number}"}}},
    "excluded_source_pointers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["/payload/body", "/payload/patch", "/payload/diff", "/payload/commits_url", "/payload/comments_url"]}},
    "canonicalization": {"const": "RFC8785_UTF8_LF_SORTED_ARRAYS_WHERE_DECLARED"}
  },
  "$defs": {
    "SourcePointer": {"enum": ["/external_object_id", "/external_version", "/payload/id", "/payload/number", "/payload/state", "/payload/title", "/payload/updated_at", "/payload/repository", "/payload/author", "/payload/base_sha", "/payload/head_sha", "/payload/requested_reviewers", "/payload/requested_teams", "/payload/labels", "/payload/draft", "/payload/linked_issue"]},
    "PointerMapping": {"type": "object", "additionalProperties": false, "required": ["source_pointer", "transform"], "properties": {"source_pointer": {"$ref": "#/$defs/SourcePointer"}, "transform": {"enum": ["identity", "github_pr_key", "canonical_sha256"]}}},
    "AttributeMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pointer", "predicate", "transform", "classification", "authority", "required"],
      "properties": {
        "source_pointer": {"$ref": "#/$defs/SourcePointer"},
        "predicate": {"enum": ["edt.engineering.title", "edt.engineering.state", "edt.engineering.repository", "edt.engineering.author", "edt.engineering.updated_at", "edt.engineering.requested_reviewers", "edt.engineering.requested_teams", "edt.engineering.draft"]},
        "transform": {"enum": ["identity", "lowercase", "rfc3339", "sort_unique"]},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "authority": {"const": "source"},
        "required": {"type": "boolean"}
      }
    },
    "RelationshipMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pointer", "predicate", "target_transform", "classification", "confidence"],
      "properties": {
        "source_pointer": {"$ref": "#/$defs/SourcePointer"},
        "predicate": {"enum": ["edt.engineering.implements", "edt.engineering.requestedreviewfrom"]},
        "target_transform": {"enum": ["jira_key", "identity", "sort_unique"]},
        "classification": {"enum": ["internal", "confidential", "restricted"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
