{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/edt/event-intelligence-event-changed.v1.json",
  "title": "Event Intelligence Event Changed CloudEvent v1",
  "description": "CloudEvents-compatible transactional-outbox envelope emitted after a synthetic Event Intelligence apply or rollback commit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "tenant_id",
    "partition_key",
    "aggregate_type",
    "aggregate_id",
    "aggregate_version",
    "causation_id",
    "correlation_id",
    "traceparent",
    "schema_version",
    "schema_hash",
    "data_classification",
    "outbox_position",
    "data"
  ],
  "properties": {
    "specversion": { "const": "1.0" },
    "id": { "type": "string", "format": "uuid" },
    "source": { "const": "urn:edt:event-intelligence" },
    "type": { "const": "com.enterprisedigitaltwin.event-intelligence.event-changed.v1" },
    "subject": {
      "type": "string",
      "pattern": "^tenant/[0-9a-f-]{36}/event/[0-9a-f-]{36}$",
      "maxLength": 500
    },
    "time": { "type": "string", "format": "date-time" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": { "const": "https://schemas.example.invalid/edt/event-intelligence-event-changed.v1.json" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "partition_key": {
      "type": "string",
      "pattern": "^tenant/[0-9a-f-]{36}/event/[0-9a-f-]{36}$"
    },
    "aggregate_type": { "const": "intelligence_event" },
    "aggregate_id": { "type": "string", "format": "uuid" },
    "aggregate_version": { "type": "integer", "minimum": 1 },
    "causation_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" },
    "traceparent": { "type": "string", "pattern": "^00-[a-f0-9]{32}-[a-f0-9]{16}-[a-f0-9]{2}$" },
    "schema_version": { "const": 1 },
    "schema_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of the RFC-8785-domain canonical JSON value of this source-controlled schema."
    },
    "data_classification": { "const": "confidential" },
    "outbox_position": {
      "type": "integer",
      "minimum": 1,
      "description": "Tenant outbox ordering position assigned in the same transaction as the event mutation."
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "approval_id",
        "interpretation_id",
        "status",
        "mode",
        "confidence_level",
        "verification_status",
        "graph_snapshot_version",
        "graph_snapshot_hash",
        "payload_hash",
        "branch_id",
        "receipt_id",
        "synthetic",
        "external_write"
      ],
      "properties": {
        "event_id": { "type": "string", "format": "uuid" },
        "approval_id": {
          "type": "string",
          "format": "uuid",
          "description": "Exact approval consumed by the apply or associated with the compensating rollback receipt."
        },
        "interpretation_id": { "type": "string", "format": "uuid" },
        "status": {
          "type": "string",
          "enum": [
            "interpreted",
            "needs_resolution",
            "reviewed",
            "approval_pending",
            "approved",
            "applied",
            "rolled_back",
            "rejected"
          ]
        },
        "mode": { "type": "string", "enum": ["reality", "scenario"] },
        "confidence_level": {
          "type": "string",
          "enum": ["confirmed", "likely", "possible", "speculative", "rejected"]
        },
        "verification_status": { "type": "string", "enum": ["unverified", "confirmed", "rejected"] },
        "graph_snapshot_version": {
          "type": "integer",
          "minimum": 1,
          "description": "Shared tenant projection version after the committed action or immutable scenario base version."
        },
        "graph_snapshot_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Canonical state hash paired with graph_snapshot_version."
        },
        "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "branch_id": {
          "oneOf": [
            { "type": "string", "format": "uuid" },
            { "type": "null" }
          ]
        },
        "receipt_id": {
          "type": "string",
          "format": "uuid",
          "description": "Receipt committed atomically with this outbox envelope."
        },
        "synthetic": { "const": true },
        "external_write": { "const": false }
      }
    }
  }
}
