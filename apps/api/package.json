{
  "name": "@edt/api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS/Fastify H1 API for the enterprise digital twin demonstrator",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "npm run test:e2e",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "fastify": "5.10.0",
    "pg": "8.16.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@types/jest": "30.0.0",
    "@types/node": "24.7.2",
    "@types/pg": "8.15.5",
    "@types/supertest": "6.0.3",
    "jest": "30.4.2",
    "supertest": "7.1.4",
    "ts-jest": "29.4.5",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
