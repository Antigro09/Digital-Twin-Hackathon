# Local H1 profile only. Replace every credential in non-local environments.
POSTGRES_PASSWORD=edt-local-postgres-only
EDT_DATABASE_NAME=edt_hardened
NEO4J_PASSWORD=edt-local-neo4j-only
MINIO_ROOT_USER=edtminio
MINIO_ROOT_PASSWORD=edt-local-minio-only
# Windows commonly reserves 9001. The MinIO console is available on 9101.
MINIO_CONSOLE_PORT=9101
# Generated automatically in the ignored .env file by `npm run demo`.
# Supply independent random values of at least 32 characters when running Compose directly.
EDT_DEMO_AUTH_SECRET=
EDT_DEMO_AUTH_BOOTSTRAP_KEY=
EDT_DEMO_UI_ACCESS_KEY=
# Generated automatically in the ignored .env file by `npm run demo`.
# Shared only between the public API and internal AI worker.
AI_WORKER_SHARED_SECRET=
AI_DATABASE_PASSWORD=

# Default platform-wide AI configuration: native Ollama DeepSeek. Both normal
# agent work and reasoning work use this route. Docker reaches host-local
# Ollama through host.docker.internal; change the endpoint for remote Ollama.
AI_PROVIDER_DEFAULT=ollama
AI_REASONING_PROVIDER=ollama
OLLAMA_MODEL=deepseek-4v-pro
OLLAMA_ENDPOINT=http://host.docker.internal:11434/api/chat
# Standard local Ollama has no API key. Set this only for an authenticated
# Ollama proxy or hosted gateway; do not put a Meta Llama or DeepSeek key here.
OLLAMA_API_KEY= 
# Optional Meta Llama provider. Select it explicitly with AI_PROVIDER_DEFAULT=llama.
# LLAMA_ENDPOINT may be left empty to use https://api.llama.com/v1/.
LLAMA_API_KEY=
LLAMA_MODEL=
LLAMA_REASONING_MODEL=
LLAMA_ENDPOINT=

# Optional evaluated fallback/provider route. It is never selected merely to
# evade a refusal, authorization failure, or structured-output validation error.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_ENDPOINT=
# Custom providers must implement the OpenAI Responses request/response contract.
# Production egress policy must independently allowlist the configured host.
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=
CUSTOM_AI_ENDPOINT=
# Optional real OpenAI-compatible embedding route. When omitted, vector
# retrieval is reported unavailable; the worker never synthesizes vectors.
# AI_EMBEDDING_API_KEY falls back to OPENAI_API_KEY when that key is configured.
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_ENDPOINT=
AI_VECTOR_DIMENSIONS=256
AI_GATEWAY_TIMEOUT_SECONDS=20
AI_GATEWAY_MAX_RETRIES=2
AI_GATEWAY_MAX_INPUT_TOKENS=24000
AI_GATEWAY_MAX_OUTPUT_TOKENS=4096
AI_GATEWAY_REQUESTS_PER_MINUTE=30
AI_GATEWAY_CACHE_TTL_SECONDS=300
AI_GATEWAY_MAX_CACHE_ENTRIES=1000
# H1 import is intentionally capped at exactly 5 MiB decoded bytes.
AI_GATEWAY_MAX_DOCUMENT_BYTES=5242880
AI_MAX_RETRIEVAL_CANDIDATES=10000
AI_SESSION_TTL_MINUTES=60
# Configure only from the selected provider's current account pricing. Unknown
# rates remain blank and monetary cost is reported as unpriced.
AI_LLAMA_INPUT_USD_PER_MILLION=
AI_LLAMA_OUTPUT_USD_PER_MILLION=
AI_OLLAMA_INPUT_USD_PER_MILLION=
AI_OLLAMA_OUTPUT_USD_PER_MILLION=
AI_OPENAI_INPUT_USD_PER_MILLION=
AI_OPENAI_OUTPUT_USD_PER_MILLION=
AI_ANTHROPIC_INPUT_USD_PER_MILLION=
AI_ANTHROPIC_OUTPUT_USD_PER_MILLION=
AI_CUSTOM_INPUT_USD_PER_MILLION=
AI_CUSTOM_OUTPUT_USD_PER_MILLION=
EDT_API_PORT=8080
EDT_WEB_PORT=3000
EDT_SYNC_PORT=8090
EDT_AI_PORT=8010
SIMULATION_WORKER_TIMEOUT_MS=60000
TEMPORAL_UI_PORT=8233
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
