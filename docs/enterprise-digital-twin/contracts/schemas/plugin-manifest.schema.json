{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/schemas/plugin-manifest.schema.json",
  "title": "Enterprise Digital Twin Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "publisher", "compatibility", "components", "permissions", "network_policy", "tenant_isolation", "supply_chain", "lifecycle"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$"},
    "name": {"type": "string", "minLength": 1, "maxLength": 160},
    "description": {"type": "string", "maxLength": 2000},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"},
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "display_name", "verification"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "verification": {"enum": ["first_party", "verified_partner", "unverified"]}
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform_api", "ontology", "contract_hashes"],
      "properties": {
        "platform_api": {"type": "string", "minLength": 1},
        "ontology": {"type": "string", "minLength": 1},
        "contract_hashes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/sha256"}}
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "version", "path", "sha256"],
        "properties": {
          "kind": {"enum": ["connector", "ontology_package", "agent_profile", "workflow", "ui_panel", "sdk_metadata"]},
          "id": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "path": {"type": "string", "pattern": "^(?!/)(?!.*\\.\\./).+$"},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purposes", "reads", "writes", "external_mutations"],
      "properties": {
        "purposes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "reads": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "writes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "external_mutations": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "destinations"],
      "properties": {
        "default": {"const": "deny"},
        "destinations": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uri", "pattern": "^https://(?!\\*)[^*]+$"}}
      }
    },
    "tenant_isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "cross_tenant_data", "cross_tenant_learning"],
      "properties": {
        "context": {"const": "server_derived"},
        "cross_tenant_data": {"const": false},
        "cross_tenant_learning": {"const": false}
      }
    },
    "supply_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_digest", "sbom_ref", "provenance_ref", "signature_ref"],
      "properties": {
        "artifact_digest": {"$ref": "#/$defs/sha256"},
        "sbom_ref": {"type": "string", "minLength": 1},
        "provenance_ref": {"type": "string", "minLength": 1},
        "signature_ref": {"type": "string", "minLength": 1}
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["install", "upgrade", "disable", "uninstall", "rollback", "deprecation_days"],
      "properties": {
        "install": {"type": "string", "minLength": 1},
        "upgrade": {"type": "string", "minLength": 1},
        "disable": {"type": "string", "minLength": 1},
        "uninstall": {"type": "string", "minLength": 1},
        "rollback": {"type": "string", "minLength": 1},
        "deprecation_days": {"type": "integer", "minimum": 30}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
