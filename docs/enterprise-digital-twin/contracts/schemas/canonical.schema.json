{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/schemas/canonical.schema.json",
  "title": "Enterprise Digital Twin Canonical Types",
  "$defs": {
    "Uuid": {"type": "string", "format": "uuid"},
    "Timestamp": {"type": "string", "format": "date-time"},
    "TenantContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "membership_id", "actor", "active_delegations", "purpose", "policy_version", "authorized_at", "home_region", "trace_context", "derived_by_server"],
      "properties": {
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "membership_id": {"$ref": "#/$defs/Uuid"},
        "actor": {"$ref": "#/$defs/Actor"},
        "active_delegations": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "purpose": {"enum": ["interactive_read", "connector_sync", "agent_analysis", "simulation", "governed_action", "administration", "audit"]},
        "policy_version": {"type": "string", "minLength": 1},
        "authorized_at": {"$ref": "#/$defs/Timestamp"},
        "home_region": {"type": "string", "minLength": 1},
        "trace_context": {"$ref": "#/$defs/TraceContext"},
        "derived_by_server": {"const": true}
      }
    },
    "Actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "actor_type", "tenant_id", "status", "assurance_level", "authenticates"],
      "properties": {
        "actor_id": {"$ref": "#/$defs/Uuid"},
        "actor_type": {"enum": ["human", "service", "agent"]},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "principal_ref": {"type": "string", "minLength": 1},
        "invoking_actor_id": {"$ref": "#/$defs/Uuid"},
        "capability_profile_id": {"type": "string", "minLength": 1},
        "delegation_id": {"$ref": "#/$defs/Uuid"},
        "status": {"enum": ["active", "suspended", "revoked", "deleted"]},
        "assurance_level": {"enum": ["unauthenticated", "aal1", "aal2", "aal3"]},
        "authenticates": {"type": "boolean"},
        "display_name": {"type": "string", "maxLength": 200}
      },
      "allOf": [
        {"if": {"properties": {"actor_type": {"const": "agent"}}}, "then": {"required": ["invoking_actor_id", "capability_profile_id", "delegation_id"], "properties": {"authenticates": {"const": false}, "assurance_level": {"const": "unauthenticated"}}}},
        {"if": {"properties": {"actor_type": {"enum": ["human", "service"]}}}, "then": {"required": ["principal_ref"], "properties": {"authenticates": {"const": true}, "assurance_level": {"enum": ["aal1", "aal2", "aal3"]}}}}
      ]
    },
    "Delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delegation_id", "principal", "delegate", "allowed_actions", "expires_at"],
      "properties": {
        "delegation_id": {"$ref": "#/$defs/Uuid"},
        "principal": {"$ref": "#/$defs/Actor"},
        "delegate": {"$ref": "#/$defs/Actor"},
        "allowed_actions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "resource_constraints": {"type": "object"},
        "expires_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ResourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "resource_type", "resource_id"],
      "properties": {
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "resource_type": {"type": "string", "minLength": 1},
        "resource_id": {"$ref": "#/$defs/Uuid"},
        "version": {"type": ["integer", "string"]}
      }
    },
    "PolicyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "effect", "enforced_as", "policy_version", "evaluated_at"],
      "properties": {
        "decision_id": {"$ref": "#/$defs/Uuid"},
        "effect": {"enum": ["allow", "deny", "indeterminate"]},
        "enforced_as": {"enum": ["allow", "deny"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "obligations": {"type": "array", "items": {"type": "object"}},
        "policy_version": {"type": "string"},
        "evaluated_at": {"$ref": "#/$defs/Timestamp"},
        "audit_event_id": {"$ref": "#/$defs/Uuid"}
      },
      "allOf": [{"if": {"properties": {"effect": {"enum": ["deny", "indeterminate"]}}}, "then": {"properties": {"enforced_as": {"const": "deny"}}}}]
    },
    "TimeInterval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from"],
      "properties": {
        "from": {"$ref": "#/$defs/Timestamp"},
        "to": {"oneOf": [{"$ref": "#/$defs/Timestamp"}, {"type": "null"}]}
      }
    },
    "SourceACL": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acl_id", "tenant_id", "source_system", "source_revision", "visibility"],
      "properties": {
        "acl_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "source_system": {"type": "string"},
        "source_revision": {"type": "string"},
        "visibility": {"enum": ["private", "restricted", "tenant", "public"]},
        "principals": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "groups": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "tenant_id", "source_object_id", "source_revision", "acl_id", "content_hash"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "source_object_id": {"type": "string"},
        "source_revision": {"type": "string"},
        "location": {"type": "string"},
        "acl_id": {"$ref": "#/$defs/Uuid"},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "classification": {"enum": ["public", "internal", "confidential", "restricted"]}
      }
    },
    "Entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "tenant_id", "type", "ontology_version", "lifecycle_state", "version"],
      "properties": {
        "entity_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "type": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
        "ontology_version": {"type": "string"},
        "lifecycle_state": {"enum": ["proposed", "active", "inactive", "archived", "deleted"]},
        "version": {"type": "integer", "minimum": 1},
        "properties": {"type": "object"},
        "classification": {"enum": ["public", "internal", "confidential", "restricted"]}
      }
    },
    "EntityVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "tenant_id", "version", "system_time", "properties_hash", "claim_ids"],
      "properties": {
        "entity_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "version": {"type": "integer", "minimum": 1},
        "system_time": {"$ref": "#/$defs/TimeInterval"},
        "properties_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "claim_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}}
      }
    },
    "OntologyType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name", "kind", "version", "status", "schema", "lifecycle", "authorization"],
      "properties": {
        "namespace": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
        "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]+$"},
        "kind": {"enum": ["entity", "relationship"]},
        "version": {"type": "string"},
        "status": {"enum": ["active", "deprecated", "retired"]},
        "schema": {"type": "object"},
        "lifecycle": {"type": "object"},
        "authorization": {"type": "object"},
        "migration": {"type": "object"}
      }
    },
    "ClaimObject": {
      "oneOf": [
        {"type": "object", "required": ["entity_id"], "properties": {"entity_id": {"$ref": "#/$defs/Uuid"}}, "additionalProperties": false},
        {"type": "object", "required": ["value"], "properties": {"value": {}}, "additionalProperties": false}
      ]
    },
    "Claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "tenant_id", "subject_id", "predicate", "object", "valid_time", "system_time", "confidence", "source_revision", "classification", "source_acl", "source_acl_hash", "evidence_ids", "acl_ids", "status"],
      "properties": {
        "claim_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "subject_id": {"$ref": "#/$defs/Uuid"},
        "predicate": {"type": "string"},
        "object": {"$ref": "#/$defs/ClaimObject"},
        "valid_time": {"$ref": "#/$defs/TimeInterval"},
        "system_time": {"$ref": "#/$defs/TimeInterval"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source_revision": {"type": "string", "minLength": 1},
        "classification": {"enum": ["public", "internal", "confidential", "restricted"]},
        "source_acl": {"$ref": "#/$defs/SourceACL"},
        "source_acl_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "acl_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "status": {"enum": ["candidate", "accepted", "rejected", "superseded", "deleted"]},
        "method": {"enum": ["deterministic_mapping", "model_extraction", "manual_assertion", "derived"]}
      }
    },
    "Relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship_id", "tenant_id", "type", "from_entity_id", "to_entity_id", "claim_ids", "valid_time", "confidence"],
      "properties": {
        "relationship_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "type": {"type": "string"},
        "from_entity_id": {"$ref": "#/$defs/Uuid"},
        "to_entity_id": {"$ref": "#/$defs/Uuid"},
        "claim_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/Uuid"}},
        "valid_time": {"$ref": "#/$defs/TimeInterval"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "weight": {"type": "number"}
      }
    },
    "ResolutionDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "tenant_id", "source_identity_ids", "outcome", "method", "confidence", "reversible", "decided_at"],
      "properties": {
        "decision_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "source_identity_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "entity_id": {"$ref": "#/$defs/Uuid"},
        "outcome": {"enum": ["merge", "do_not_merge", "split", "needs_review"]},
        "method": {"enum": ["deterministic", "reviewed_model_proposal", "human_review"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "reversible": {"const": true},
        "decided_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "SourceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "installation_id", "provider", "provider_id", "provider_revision", "observed_at", "content_hash", "acl_id"],
      "properties": {
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "installation_id": {"$ref": "#/$defs/Uuid"},
        "provider": {"type": "string"},
        "provider_id": {"type": "string"},
        "provider_revision": {"type": "string"},
        "observed_at": {"$ref": "#/$defs/Timestamp"},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "acl_id": {"$ref": "#/$defs/Uuid"},
        "deleted": {"type": "boolean", "default": false}
      }
    },
    "NormalizedObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_id", "tenant_id", "installation_id", "source_object_id", "mapping_version", "observed_at", "received_at", "payload_hash", "acl_id", "status"],
      "properties": {
        "observation_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "installation_id": {"$ref": "#/$defs/Uuid"},
        "source_object_id": {"type": "string"},
        "mapping_version": {"type": "string"},
        "observed_at": {"$ref": "#/$defs/Timestamp"},
        "received_at": {"$ref": "#/$defs/Timestamp"},
        "payload_ref": {"type": "string"},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "acl_id": {"$ref": "#/$defs/Uuid"},
        "status": {"enum": ["active", "tombstone", "quarantined", "superseded"]}
      }
    },
    "SyncCursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "installation_id", "stream", "cursor", "checkpointed_at"],
      "properties": {
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "installation_id": {"$ref": "#/$defs/Uuid"},
        "stream": {"type": "string"},
        "cursor": {"type": "string"},
        "checkpointed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ProjectionCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "projection", "outbox_position", "ontology_version", "completed_at"],
      "properties": {
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "projection": {"type": "string"},
        "outbox_position": {"type": "integer", "minimum": 0},
        "ontology_version": {"type": "string"},
        "completed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "AgentRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "tenant_id", "profile_id", "status", "model_config_version", "policy_version", "budget", "created_at"],
      "properties": {
        "run_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "profile_id": {"type": "string"},
        "status": {"enum": ["queued", "running", "awaiting_input", "awaiting_approval", "succeeded", "failed", "cancelled", "budget_exhausted"]},
        "model_config_version": {"type": "string"},
        "policy_version": {"type": "string"},
        "budget": {"type": "object", "required": ["max_seconds", "max_tokens", "max_cost_units", "max_tools"], "properties": {"max_seconds": {"type": "integer", "minimum": 1}, "max_tokens": {"type": "integer", "minimum": 1}, "max_cost_units": {"type": "number", "minimum": 0}, "max_tools": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ToolInvocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invocation_id", "run_id", "tenant_id", "tool", "arguments_hash", "policy_decision_id", "status"],
      "properties": {
        "invocation_id": {"$ref": "#/$defs/Uuid"},
        "run_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "tool": {"type": "string"},
        "arguments_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "policy_decision_id": {"$ref": "#/$defs/Uuid"},
        "status": {"enum": ["proposed", "denied", "approved", "running", "succeeded", "failed", "compensated"]}
      }
    },
    "JiraIssueUpdateArguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "action", "connector_installation_id", "expected_issue_version", "issue_key", "project_key", "set"],
      "properties": {
        "tenant_id": {"const": "10000000-0000-4000-8000-000000000001"},
        "action": {"const": "jira.issue.update"},
        "connector_installation_id": {"const": "30000000-0000-4000-8000-000000000001"},
        "expected_issue_version": {"const": 7},
        "issue_key": {"const": "AST-142"},
        "project_key": {"const": "AST"},
        "set": {
          "type": "object",
          "additionalProperties": false,
          "required": ["due_date", "labels", "priority_id"],
          "properties": {
            "due_date": {"const": "2026-07-31"},
            "labels": {"type": "array", "prefixItems": [{"const": "digital-twin-remediation"}, {"const": "identity"}, {"const": "orion"}], "items": false, "minItems": 3, "maxItems": 3, "uniqueItems": true},
            "priority_id": {"const": "2"}
          }
        }
      },
      "description": "The only H1 executable mutation. The payload hash is SHA-256 over this RFC 8785 canonical object and no governance metadata is sent to Jira."
    },
    "JiraIssueSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_key", "version", "fields"],
      "properties": {
        "issue_key": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "required": ["due_date", "labels", "priority_id", "priority_name"],
          "properties": {
            "due_date": {"type": "string", "format": "date"},
            "labels": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
            "priority_id": {"type": "string"},
            "priority_name": {"type": "string"}
          }
        }
      }
    },
    "ApprovedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_payload_id", "tenant_id", "action", "connector_installation_id", "target", "canonical_arguments", "payload_hash", "idempotency_key", "policy_version", "credential_version", "issued_at", "expires_at"],
      "properties": {
        "approved_payload_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "action": {"const": "jira.issue.update"},
        "connector_installation_id": {"$ref": "#/$defs/Uuid"},
        "target": {"$ref": "#/$defs/ResourceRef"},
        "canonical_arguments": {"$ref": "#/$defs/JiraIssueUpdateArguments"},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 of RFC 8785 canonical JiraIssueUpdateArguments."},
        "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 128},
        "policy_version": {"type": "string"},
        "credential_version": {"type": "string"},
        "issued_at": {"$ref": "#/$defs/Timestamp"},
        "expires_at": {"$ref": "#/$defs/Timestamp"}
      },
      "description": "expires_at is no more than 15 minutes after issued_at. Runtime canonicalization rejects duplicate keys, non-UTF-8 text, non-finite numbers, and any field outside JiraIssueUpdateArguments."
    },
    "ApprovalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_id", "tenant_id", "requester_id", "approved_payload_id", "action_type", "payload_hash", "approval_binding_hash", "idempotency_key", "policy_version", "credential_version", "reason", "evidence_ids", "simulation_id", "before_snapshot_hash", "created_at", "expires_at", "required_approvals", "required_roles", "decision_ids", "status"],
      "properties": {
        "approval_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "requester_id": {"$ref": "#/$defs/Uuid"},
        "approved_payload_id": {"$ref": "#/$defs/Uuid"},
        "action_type": {"const": "jira.issue.update"},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "approval_binding_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$", "description": "SHA-256 over an RFC 8785 canonical approval envelope containing tenant, requester, approved payload ID/hash, idempotency key, policy and credential versions, reason, sorted evidence IDs, simulation ID, before-state hash, required roles, created_at, and expires_at. Any change creates a new request and invalidates prior decisions."},
        "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 128},
        "policy_version": {"type": "string"},
        "credential_version": {"type": "string"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 2000},
        "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "simulation_id": {"$ref": "#/$defs/Uuid"},
        "before_snapshot_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "expires_at": {"$ref": "#/$defs/Timestamp"},
        "required_approvals": {"const": 2},
        "required_roles": {"type": "array", "prefixItems": [{"const": "operations_approver"}, {"const": "security_approver"}], "items": false},
        "decision_ids": {"type": "array", "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "action_grant_id": {"$ref": "#/$defs/Uuid"},
        "status": {"enum": ["pending", "approved", "denied", "expired", "cancelled", "executed", "compensated"]}
      },
      "allOf": [
        {"if": {"properties": {"status": {"enum": ["approved", "executed", "compensated"]}}}, "then": {"required": ["action_grant_id"], "properties": {"decision_ids": {"minItems": 2, "maxItems": 2}}}},
        {"if": {"properties": {"status": {"const": "denied"}}}, "then": {"properties": {"decision_ids": {"minItems": 1}}}}
      ],
      "description": "The service enforces two distinct active human approvers in the required roles, AAL2 or stronger, neither equal to requester, and expires_at no more than 15 minutes after created_at."
    },
    "ApprovalDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "approval_id", "tenant_id", "approver_id", "membership_id", "role", "decision", "approval_binding_hash", "policy_version", "assurance_level", "authenticated_human", "decided_at"],
      "properties": {
        "decision_id": {"$ref": "#/$defs/Uuid"},
        "approval_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "approver_id": {"$ref": "#/$defs/Uuid"},
        "membership_id": {"$ref": "#/$defs/Uuid"},
        "role": {"enum": ["operations_approver", "security_approver"]},
        "decision": {"enum": ["approve", "deny"]},
        "approval_binding_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "policy_version": {"type": "string", "minLength": 1},
        "assurance_level": {"enum": ["aal2", "aal3"]},
        "authenticated_human": {"const": true},
        "comment": {"type": "string", "maxLength": 1000},
        "decided_at": {"$ref": "#/$defs/Timestamp"}
      },
      "description": "At acceptance time the runtime reauthorizes membership, role, policy version, expiry, binding hash, and distinctness from requester and every other approver."
    },
    "ActionGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grant_id", "tenant_id", "approval_id", "approved_payload_id", "action", "target", "expected_provider_version", "payload_hash", "approval_binding_hash", "decision_ids", "single_use", "state", "issued_at", "expires_at"],
      "properties": {
        "grant_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "approval_id": {"$ref": "#/$defs/Uuid"},
        "approved_payload_id": {"$ref": "#/$defs/Uuid"},
        "action": {"const": "jira.issue.update"},
        "target": {"$ref": "#/$defs/ResourceRef"},
        "expected_provider_version": {"const": 7},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "approval_binding_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "decision_ids": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "single_use": {"const": true},
        "state": {"enum": ["available", "claimed", "consumed", "revoked"]},
        "issued_at": {"$ref": "#/$defs/Timestamp"},
        "expires_at": {"$ref": "#/$defs/Timestamp"},
        "claimed_at": {"$ref": "#/$defs/Timestamp"},
        "consumed_at": {"$ref": "#/$defs/Timestamp"}
      },
      "allOf": [
        {"if": {"properties": {"state": {"enum": ["claimed", "consumed"]}}}, "then": {"required": ["claimed_at"]}},
        {"if": {"properties": {"state": {"const": "consumed"}}}, "then": {"required": ["consumed_at"]}}
      ],
      "description": "Claiming is an atomic compare-and-set before any provider call. A consumed, expired, or revoked grant can never return to available."
    },
    "ActionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_id", "tenant_id", "approval_id", "approved_payload_id", "grant_id", "payload_hash", "approval_binding_hash", "decision_ids", "idempotency_key", "provider", "provider_resource_id", "execution_started_at", "recorded_at", "trace_id", "status"],
      "properties": {
        "receipt_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "approval_id": {"$ref": "#/$defs/Uuid"},
        "approved_payload_id": {"$ref": "#/$defs/Uuid"},
        "grant_id": {"$ref": "#/$defs/Uuid"},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "approval_binding_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "decision_ids": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 128},
        "provider": {"const": "jira"},
        "provider_resource_id": {"type": "string"},
        "provider_request_id": {"type": "string"},
        "before_snapshot": {"$ref": "#/$defs/JiraIssueSnapshot"},
        "after_snapshot": {"$ref": "#/$defs/JiraIssueSnapshot"},
        "before_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "after_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "execution_started_at": {"$ref": "#/$defs/Timestamp"},
        "recorded_at": {"$ref": "#/$defs/Timestamp"},
        "failure_stage": {"enum": ["preflight", "grant_claim", "provider_call", "provider_response", "verification", "receipt_persist"]},
        "provider_response_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "trace_id": {"type": "string"},
        "status": {"enum": ["succeeded", "failed", "verification_required", "compensated", "compensation_conflict", "manual_intervention_required"]}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "succeeded"}}}, "then": {"required": ["provider_request_id", "before_snapshot", "after_snapshot", "before_hash", "after_hash", "provider_response_hash"]}},
        {"if": {"properties": {"status": {"const": "failed"}}}, "then": {"required": ["failure_stage"]}},
        {"if": {"properties": {"status": {"enum": ["verification_required", "compensated", "compensation_conflict", "manual_intervention_required"]}}}, "then": {"required": ["before_snapshot", "before_hash"]}}
      ],
      "description": "A failed preflight or grant claim need not invent provider IDs or snapshots. Ambiguous provider outcomes use verification_required and are reconciled before any retry."
    },
    "CompensationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compensation_id", "tenant_id", "original_receipt_id", "approval_id", "idempotency_key", "status", "attempted_at", "trace_id"],
      "properties": {
        "compensation_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "original_receipt_id": {"$ref": "#/$defs/Uuid"},
        "approval_id": {"$ref": "#/$defs/Uuid"},
        "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 128},
        "status": {"enum": ["restored", "compensation_conflict", "verification_required", "failed", "manual_intervention_required"]},
        "restored_snapshot_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "reason_code": {"type": "string"},
        "attempted_at": {"$ref": "#/$defs/Timestamp"},
        "trace_id": {"type": "string"}
      }
    },
    "Assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assumption_id", "statement", "status", "source"],
      "properties": {
        "assumption_id": {"$ref": "#/$defs/Uuid"},
        "statement": {"type": "string", "minLength": 1},
        "status": {"enum": ["confirmed", "inferred_from_evidence", "missing", "contested"]},
        "source": {"enum": ["user", "evidence", "model_default", "engine_default"]},
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}}
      }
    },
    "Uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "sample_count", "seed", "quantiles", "warnings"],
      "properties": {
        "method": {"const": "seeded_pert_monte_carlo"},
        "sample_count": {"type": "integer", "minimum": 1},
        "seed": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$", "description": "Unsigned 64-bit decimal string; the runtime enforces the uint64 maximum."},
        "quantiles": {"type": "object", "required": ["p50", "p80", "p95"], "properties": {"p50": {"type": "string", "format": "date"}, "p80": {"type": "string", "format": "date"}, "p95": {"type": "string", "format": "date"}}, "additionalProperties": false},
        "batch_standard_errors_days": {"type": "object"},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    },
    "SimulationSnapshot": {"$ref": "./simulation-snapshot.schema.json"},
    "Scenario": {"$ref": "./scenario.schema.json"},
    "LaunchForecastSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p50", "p80", "p95"],
      "properties": {
        "p50": {"type": "string", "format": "date"},
        "p80": {"type": "string", "format": "date"},
        "p95": {"type": "string", "format": "date"},
        "probability_on_or_before_target": {"type": "number", "minimum": 0, "maximum": 1},
        "probability_after_target": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "PairedDeltaArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "sha256", "count", "encoding"],
      "properties": {
        "uri": {"type": "string", "format": "uri-reference", "description": "Authorized immutable artifact route, never a bearer object-store URL."},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "count": {"type": "integer", "minimum": 1, "maximum": 75000},
        "encoding": {"enum": ["application/json+gzip", "application/vnd.apache.arrow.file"]}
      }
    },
    "SimulationRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["simulation_id", "tenant_id", "snapshot_id", "snapshot_hash", "scenario_id", "scenario_hash", "engine_version", "calendar_version", "seed", "sample_count", "target_date", "status", "created_at"],
      "properties": {
        "simulation_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "snapshot_id": {"$ref": "#/$defs/Uuid"},
        "snapshot_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "scenario_id": {"oneOf": [{"$ref": "#/$defs/Uuid"}, {"type": "null"}], "description": "Null only for the immutable zero-intervention baseline run."},
        "scenario_hash": {"oneOf": [{"type": "string", "pattern": "^[a-f0-9]{64}$"}, {"type": "null"}]},
        "engine_version": {"type": "string"},
        "calendar_version": {"type": "string"},
        "seed": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"},
        "sample_count": {"type": "integer", "minimum": 1},
        "target_date": {"type": ["string", "null"], "format": "date"},
        "status": {"enum": ["queued", "running", "succeeded", "failed", "cancelled"]},
        "uncertainty": {"$ref": "#/$defs/Uncertainty"},
        "probability_on_or_before_target": {"type": "number", "minimum": 0, "maximum": 1},
        "probability_after_target": {"type": "number", "minimum": 0, "maximum": 1},
        "critical_path": {"type": "array", "items": {"$ref": "#/$defs/Uuid"}},
        "criticality": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["work_item_id", "index"], "properties": {"work_item_id": {"$ref": "#/$defs/Uuid"}, "index": {"type": "number", "minimum": 0, "maximum": 1, "description": "Fraction of committed iterations in which total slack is at most 1e-9 workdays."}}}},
        "blockers": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["work_item_id", "label", "criticality", "evidence_ids"], "properties": {"work_item_id": {"$ref": "#/$defs/Uuid"}, "label": {"type": "string"}, "criticality": {"type": "number", "minimum": 0, "maximum": 1}, "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}}}}},
        "sensitivity": {"type": "array", "maxItems": 20, "items": {"type": "object", "additionalProperties": false, "required": ["factor", "method", "score", "absolute_rank", "criticality_index"], "properties": {"factor": {"type": "string"}, "method": {"enum": ["spearman_rank", "criticality_index", "controlled_delta"]}, "score": {"type": "number", "minimum": -1, "maximum": 1}, "absolute_rank": {"type": "integer", "minimum": 1, "maximum": 20}, "criticality_index": {"type": "number", "minimum": 0, "maximum": 1}, "unstable": {"type": "boolean"}, "source_estimate": {"type": "object", "additionalProperties": false, "required": ["optimistic", "most_likely", "pessimistic", "unit"], "properties": {"optimistic": {"type": "number"}, "most_likely": {"type": "number"}, "pessimistic": {"type": "number"}, "unit": {"const": "workday"}}}, "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}}}}},
        "assumptions": {"type": "array", "items": {"$ref": "#/$defs/Assumption"}},
        "missing_data": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 2000}},
        "warnings": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 2000}},
        "baseline_comparison": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["baseline_simulation_id", "baseline_forecast", "scenario_forecast", "paired_deltas", "p50_delta_workdays", "p80_delta_workdays", "p95_delta_workdays", "probability_of_improvement", "changed_criticality", "critical_path_changed", "negative_delta_means"],
              "properties": {
                "baseline_simulation_id": {"$ref": "#/$defs/Uuid"},
                "baseline_forecast": {"$ref": "#/$defs/LaunchForecastSummary"},
                "scenario_forecast": {"$ref": "#/$defs/LaunchForecastSummary"},
                "paired_deltas": {
                  "oneOf": [
                    {"type": "array", "minItems": 1, "maxItems": 75000, "items": {"type": "number"}},
                    {"$ref": "#/$defs/PairedDeltaArtifact"}
                  ]
                },
                "p50_delta_workdays": {"type": "number"},
                "p80_delta_workdays": {"type": "number"},
                "p95_delta_workdays": {"type": "number"},
                "probability_of_improvement": {"type": "number", "minimum": 0, "maximum": 1},
                "changed_criticality": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["work_item_id", "baseline_index", "scenario_index", "delta"], "properties": {"work_item_id": {"$ref": "#/$defs/Uuid"}, "baseline_index": {"type": "number", "minimum": 0, "maximum": 1}, "scenario_index": {"type": "number", "minimum": 0, "maximum": 1}, "delta": {"type": "number", "minimum": -1, "maximum": 1}}}},
                "critical_path_changed": {"type": "boolean"},
                "negative_delta_means": {"const": "earlier_completion"}
              }
            },
            {"type": "null"}
          ]
        },
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "result_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "completed_at": {"$ref": "#/$defs/Timestamp"}
      },
      "allOf": [
        {"if": {"properties": {"status": {"const": "succeeded"}}}, "then": {"required": ["uncertainty", "critical_path", "criticality", "blockers", "sensitivity", "assumptions", "missing_data", "warnings", "baseline_comparison", "evidence_ids", "result_sha256", "completed_at"]}},
        {"if": {"properties": {"status": {"const": "succeeded"}, "target_date": {"type": "string"}}, "required": ["target_date"]}, "then": {"required": ["probability_on_or_before_target", "probability_after_target"]}}
      ]
    },
    "Forecast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forecast_id", "tenant_id", "outcome", "window", "model_version", "lineage", "calibration_status", "prohibited_uses", "status"],
      "properties": {
        "forecast_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "outcome": {"type": "string"},
        "window": {"$ref": "#/$defs/TimeInterval"},
        "model_version": {"type": "string"},
        "lineage": {"type": "array", "items": {"$ref": "#/$defs/Uuid"}},
        "calibration_status": {"enum": ["unvalidated", "calibrated", "degraded", "withdrawn"]},
        "drift_status": {"enum": ["unknown", "stable", "warning", "failed"]},
        "prohibited_uses": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "status": {"enum": ["research", "provisional", "committed", "withdrawn"]}
      }
    },
    "TraceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceparent", "request_id"],
      "properties": {
        "traceparent": {"type": "string", "pattern": "^00-[a-f0-9]{32}-[a-f0-9]{16}-[a-f0-9]{2}$"},
        "tracestate": {"type": "string", "maxLength": 512},
        "request_id": {"$ref": "#/$defs/Uuid"},
        "tenant_safe_baggage": {"type": "object", "propertyNames": {"pattern": "^(?!tenant$|actor$|authorization$|credential$).+"}, "additionalProperties": {"type": "string", "maxLength": 256}}
      }
    },
    "AuditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "tenant_id", "tenant_sequence", "occurred_at", "recorded_at", "actor", "authentication_assurance", "delegation_ids", "action", "resource", "outcome", "policy_decision_id", "policy_version", "request_id", "trace_id", "source_ip_classification", "data_classification", "previous_hash", "event_hash"],
      "properties": {
        "event_id": {"$ref": "#/$defs/Uuid"},
        "tenant_id": {"$ref": "#/$defs/Uuid"},
        "tenant_sequence": {"type": "integer", "minimum": 1},
        "occurred_at": {"$ref": "#/$defs/Timestamp"},
        "recorded_at": {"$ref": "#/$defs/Timestamp"},
        "actor": {"$ref": "#/$defs/Actor"},
        "authentication_assurance": {"enum": ["unauthenticated", "aal1", "aal2", "aal3", "workload_identity"]},
        "delegation_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/Uuid"}},
        "action": {"type": "string"},
        "resource": {"$ref": "#/$defs/ResourceRef"},
        "outcome": {"enum": ["allowed", "denied", "succeeded", "failed"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "policy_decision_id": {"$ref": "#/$defs/Uuid"},
        "policy_version": {"type": "string", "minLength": 1},
        "request_id": {"$ref": "#/$defs/Uuid"},
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "source_ip_classification": {"enum": ["public", "private", "loopback", "link_local", "unknown", "redacted"]},
        "data_classification": {"enum": ["public", "internal", "confidential", "restricted"]},
        "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 128},
        "before_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "after_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "redacted_diff": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["op", "path"], "properties": {"op": {"enum": ["add", "remove", "replace", "test"]}, "path": {"type": "string", "pattern": "^/"}, "value_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
        "previous_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "event_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "description": "Sequences are monotonic per tenant. event_hash is an RFC 8785 canonical record digest chained to previous_hash; a signed tenant/day root is exported to independent retention. Raw IPs, tokens, secrets, prompts, and source payloads are excluded."
    },
    "Problem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "title", "status", "code", "instance", "trace_id", "retryable"],
      "properties": {
        "type": {"type": "string", "format": "uri-reference"},
        "title": {"type": "string"},
        "status": {"type": "integer", "minimum": 400, "maximum": 599},
        "code": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"},
        "detail": {"type": "string"},
        "instance": {"type": "string", "format": "uri-reference"},
        "trace_id": {"type": "string"},
        "request_id": {"type": "string"},
        "retryable": {"type": "boolean"},
        "retry_after": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "string", "format": "date-time"}]},
        "errors": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
