{
  "schema_version": "1.0",
  "id": "com.enterprise-digital-twin.connector.github",
  "version": "1.0.0",
  "publisher": {
    "id": "com.enterprise-digital-twin",
    "display_name": "Enterprise Digital Twin",
    "owning_team": "connector-platform",
    "support_uri": "https://support.enterprise-digital-twin.example/connectors/github",
    "security_contact": "security@enterprise-digital-twin.example"
  },
  "provider": "github",
  "deployment": {
    "supported_variants": ["github_cloud"],
    "runtime_mode": "network_restricted_connector_worker",
    "oci_image_digest": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
    "minimum_worker_version": "1.0.0",
    "installation_isolation": "tenant_scoped_credentials_queues_cursors_and_egress"
  },
  "auth": {
    "type": "github_app_installation",
    "required_permissions": [
      {"name": "metadata", "access": "read"},
      {"name": "contents", "access": "read"},
      {"name": "pull_requests", "access": "read"},
      {"name": "actions", "access": "read"},
      {"name": "checks", "access": "read"},
      {"name": "deployments", "access": "read"},
      {"name": "members", "access": "read"}
    ],
    "forbidden_permissions": ["administration", "secrets", "variables", "billing", "emails", "security_events", "repository_hooks_write"],
    "credential_lifetime_seconds": 3600,
    "refresh_behavior": "mint_short_lived_installation_token",
    "secret_storage": "tenant_scoped_envelope_encrypted_reference",
    "effective_grant_policy": "reject_missing_required_or_any_forbidden_permission"
  },
  "capabilities": {
    "reads": [
      {"resource": "installation_repositories", "operations": ["discover", "backfill", "reconcile", "acl_sync"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "metadata:read", "reconciliation_fetch": "GET /installation/repositories"},
      {"resource": "repository_metadata", "operations": ["discover", "backfill", "incremental", "reconcile", "acl_sync"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "metadata:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}"},
      {"resource": "branches", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "contents:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/branches"},
      {"resource": "commits", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "contents:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/commits"},
      {"resource": "comparisons", "operations": ["incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "contents:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/compare/{base}...{head}"},
      {"resource": "pull_requests", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "webhook_then_authenticated_get", "required_permission": "pull_requests:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/pulls"},
      {"resource": "pull_request_reviews", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "pull_requests:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/pulls/{number}/reviews"},
      {"resource": "workflow_runs", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "actions:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/actions/runs"},
      {"resource": "workflow_jobs", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "actions:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/actions/runs/{run_id}/jobs"},
      {"resource": "check_runs", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "checks:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/commits/{ref}/check-runs"},
      {"resource": "deployments", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "deployments:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/deployments"},
      {"resource": "deployment_statuses", "operations": ["backfill", "incremental", "reconcile"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "deployments:read", "reconciliation_fetch": "GET /repos/{owner}/{repo}/deployments/{deployment_id}/statuses"},
      {"resource": "organization_members", "operations": ["backfill", "incremental", "reconcile", "acl_sync"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "members:read", "reconciliation_fetch": "GET /orgs/{org}/members"},
      {"resource": "teams", "operations": ["backfill", "incremental", "reconcile", "acl_sync"], "pagination": "link_header", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "members:read", "reconciliation_fetch": "GET /orgs/{org}/teams"}
    ],
    "events": [
      {"event": "installation", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "installation_repositories"},
      {"event": "installation_repositories", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "installation_repositories"},
      {"event": "repository", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "repository_metadata"},
      {"event": "push", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "commits"},
      {"event": "pull_request", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "pull_requests"},
      {"event": "pull_request_review", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "pull_request_reviews"},
      {"event": "workflow_run", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "workflow_runs"},
      {"event": "check_run", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "check_runs"},
      {"event": "deployment", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "deployments"},
      {"event": "deployment_status", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "deployment_statuses"},
      {"event": "membership", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "organization_members"},
      {"event": "team", "delivery_id_source": "X-GitHub-Delivery", "verification_profile": "github_hmac_sha256_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "teams"}
    ],
    "mutations": []
  },
  "schemas": {
    "raw_envelope": {"uri": "schemas/raw-envelope.schema.json", "id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/raw-envelope.schema.json", "version": "1.0.0", "sha256": "66fe03eb862a38c331d5199cfdd50cff6beb1f03694990095e0155cb06a41757"},
    "raw_payload": {"uri": "schemas/raw-payload.schema.json", "id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/raw-payload.schema.json", "version": "1.0.0", "sha256": "9f592481f77a877b41c5c93ec5d772297af9a7e26b2bfc40184f049b1c98f6a9"},
    "normalized_observation": {"uri": "schemas/normalized-observation.schema.json", "id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/normalized-observation.schema.json", "version": "1.0.0", "sha256": "4e18a9aa01a9b56a376b71de8d33e91cb4f1bd859ff801cfc704ce2eb030aa2a"},
    "cursor": {"uri": "schemas/cursor.schema.json", "id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/cursor.schema.json", "version": "1.0.0", "sha256": "81ec8545ee4ca691f2fac81b2df36ba275a545c24706703702df37257ad1491f"},
    "ontology_mapping": {"uri": "schemas/ontology-mapping.schema.json", "id": "https://enterprise-digital-twin.example/connectors/github/1.0.0/ontology-mapping.schema.json", "version": "1.0.0", "sha256": "550941183af4f7e415229f8408977169429a0009364bcc07ca349649d8edaeb7"}
  },
  "rate_limits": {
    "buckets": [{"name": "github_core", "limit": 5000, "window_seconds": 3600}, {"name": "github_search", "limit": 30, "window_seconds": 60}],
    "quota_scope": "installation",
    "max_concurrency_per_installation": 4,
    "tenant_fairness_weight": 1,
    "request_timeout_seconds": 30,
    "retry_classes": ["rate_limit", "provider_5xx", "network_timeout"],
    "backoff": {"minimum_seconds": 1, "maximum_seconds": 300, "jitter": "full", "honor_retry_after": true, "maximum_attempts": 8}
  },
  "cursor": {"schema_ref": "schemas/cursor.schema.json", "commit_granularity": "same_transaction_as_observations_and_outbox", "overlap_seconds": 600, "lookback_days": 180, "reset_modes": ["resume", "rewind_overlap", "authorized_full_reconcile"], "reset_authorization": "connector_admin_and_audited_preview", "last_good_checkpoint": "preserve_until_replacement_commits"},
  "data_policy": {
    "included_fields": ["repository_identity", "visibility", "topics", "branch_and_commit_metadata", "pull_request_metadata", "review_state", "workflow_run_metadata", "check_status", "deployment_status", "member_and_team_identity"],
    "excluded_fields": ["source_file_bodies", "repository_archives", "patches_and_diffs", "secrets", "variables", "actions_logs", "private_messages", "billing", "email", "security_alert_bodies"],
    "classifications": ["internal", "confidential", "restricted"],
    "raw_retention_class": "connector_raw_h1",
    "normalized_retention_class": "connector_observation_h1",
    "limits": {"max_payload_bytes": 10485760, "max_nesting_depth": 64, "max_string_bytes": 1048576, "max_decompression_ratio": 20, "parse_deadline_seconds": 30},
    "redaction_policy": "secrets_tokens_authorization_headers_and_disallowed_bodies",
    "untrusted_content": true,
    "training_use": "prohibited"
  },
  "network_policy": {
    "rules": [{"host": "api.github.com", "port": 443, "path_prefixes": ["/app/installations/", "/installation/repositories", "/orgs/", "/organizations/", "/repos/"]}],
    "tls_minimum": "1.2",
    "dns_revalidation": "each_connection_and_redirect",
    "deny_private_link_local_metadata": true,
    "redirect_limit": 0,
    "response_size_limit_bytes": 10485760,
    "connect_deadline_seconds": 5,
    "read_deadline_seconds": 30,
    "manifest_proxy_allowed": false
  },
  "health": {
    "checks": [
      {"type": "credential", "interval_seconds": 300, "timeout_seconds": 10, "failure_threshold": 2, "transition": "suspended", "diagnostic_code": "CONN_GITHUB_CREDENTIAL"},
      {"type": "webhook", "interval_seconds": 300, "timeout_seconds": 10, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_GITHUB_WEBHOOK"},
      {"type": "freshness", "interval_seconds": 300, "timeout_seconds": 5, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_GITHUB_FRESHNESS"},
      {"type": "quota", "interval_seconds": 60, "timeout_seconds": 5, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_GITHUB_QUOTA"},
      {"type": "reconciliation", "interval_seconds": 900, "timeout_seconds": 30, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_GITHUB_RECONCILIATION"}
    ],
    "freshness_slo_seconds": 900,
    "webhook_ack_p95_seconds": 2
  },
  "support": {"compatibility": ">=1.0.0 <2.0.0", "deprecation_state": "active", "sunset_at": null, "owning_service": "connector-worker", "runbook_uri": "https://runbooks.enterprise-digital-twin.example/connectors/github", "security_escalation": "security@enterprise-digital-twin.example"}
}
