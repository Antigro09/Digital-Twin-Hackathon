{
  "name": "@edt/sync-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Deterministic GitHub/Jira provider simulator and synchronization/projection worker",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1086.0",
