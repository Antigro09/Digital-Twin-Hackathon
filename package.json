{
  "name": "enterprise-digital-twin",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable H1 enterprise digital twin demonstrator and its source-controlled architecture specification",
  "workspaces": [
    "apps/api",
    "apps/sync-worker",
    "apps/web"
  ],
  "scripts": {
    "render:diagrams": "node scripts/render_diagrams.mjs",
    "docs:validate": "python scripts/validate_blueprint.py",
    "docs:build": "python scripts/build_blueprint.py",
    "docs:pdf": "python scripts/render_pdf.py",
    "docs": "npm run render:diagrams && npm run docs:validate && npm run docs:build && npm run docs:pdf",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && python -m pytest apps/ai-worker/tests -q",
    "test:e2e": "npm run test:e2e -w @edt/api",
    "dev:api": "npm run start:dev -w @edt/api",
    "dev:web": "npm run dev -w @edt/web",
    "dev:sync": "npm run start:dev -w @edt/sync-worker",
    "demo": "node scripts/edt.mjs start",
    "demo:seed": "node scripts/edt.mjs seed",
    "demo:verify": "node scripts/edt.mjs verify",
    "demo:token": "node scripts/edt.mjs auth-token"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "11.16.0"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "postcss": "8.5.19",
    "webpack": "5.108.4"
  },
  "overrides": {
    "ajv": "8.20.0",
    "next@16.2.10": {
      "postcss": "$postcss"
    },
    "postcss": "8.5.19",
    "@temporalio/worker": {
      "webpack": "5.108.4"
    },
    "webpack": "5.108.4"
  },
  "engines": {
    "node": ">=22"
  }
}
