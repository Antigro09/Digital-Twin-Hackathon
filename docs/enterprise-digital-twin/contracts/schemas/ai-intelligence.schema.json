{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.enterprise-digital-twin.example/ai-intelligence/v1",
  "title": "AI Intelligence Gateway Contracts",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "agentType": {
      "enum": [
        "knowledge_ingestion",
        "entity_resolution",
        "event_understanding",
        "causal_analysis",
        "simulation_planning",
        "prediction_explanation",
        "technical_knowledge"
      ]
    },
    "classification": {
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "publicSourceAcl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility"],
      "properties": {
        "visibility": {
          "const": "private",
          "description": "H1 expands this server-side to the authenticated importing actor; caller-supplied principals are prohibited."
        }
      }
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "measurement": {"enum": ["provider_reported", "unavailable", "cache_hit"]}
      }
    },
    "providerStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "configured", "model", "live_provider_verified"],
      "properties": {
        "provider": {"enum": ["llama", "openai"]},
        "configured": {"type": "boolean"},
        "model": {"type": ["string", "null"], "minLength": 1, "maxLength": 500},
        "live_provider_verified": {"const": false, "description": "Static configuration never proves a live provider call; release evidence may set an external verification result, but this runtime status remains fail-closed."}
      }
    },
    "aiStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "providers", "agents", "storage_backend", "durable_store_ready", "vector_configured", "vector_ready", "retrieval_modes", "model_outputs_mutate_state"],
      "properties": {
        "status": {"enum": ["ready", "degraded"]},
        "providers": {"type": "array", "maxItems": 10, "items": {"$ref": "#/$defs/providerStatus"}},
        "agents": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"$ref": "#/$defs/agentType"}},
        "storage_backend": {"type": "string", "minLength": 1, "maxLength": 100},
        "durable_store_ready": {"type": "boolean"},
        "vector_configured": {"type": "boolean"},
        "vector_ready": {"type": "boolean"},
        "retrieval_modes": {"type": "array", "uniqueItems": true, "items": {"enum": ["lexical", "vector"]}},
        "model_outputs_mutate_state": {"const": false}
      }
    },
    "activityRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activity_id", "tenant_id", "actor_id", "agent_type", "kind", "state", "provider", "model", "usage", "cost_usd", "cost_status", "evidence_ids", "error_code", "created_at"],
      "properties": {
        "activity_id": {"$ref": "#/$defs/uuid"},
        "tenant_id": {"$ref": "#/$defs/uuid"},
        "actor_id": {"$ref": "#/$defs/uuid"},
        "agent_type": {"anyOf": [{"$ref": "#/$defs/agentType"}, {"type": "null"}]},
        "kind": {"enum": ["agent_run", "document_import", "retrieval", "suggestion_review", "learning_outcome"]},
        "state": {"enum": ["running", "succeeded", "failed"]},
        "provider": {"enum": ["llama", "openai", null]},
        "model": {"type": ["string", "null"], "maxLength": 500},
        "usage": {"anyOf": [{"$ref": "#/$defs/tokenUsage"}, {"type": "null"}]},
        "cost_usd": {"type": ["number", "string", "null"]},
        "cost_status": {"enum": ["priced", "unpriced", "not_applicable"]},
        "evidence_ids": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/uuid"}},
        "error_code": {"type": ["string", "null"], "maxLength": 200},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "activityList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/activityRecord"}}
      }
    },
    "agentRunRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_type", "input"],
      "properties": {
        "agent_type": {"$ref": "#/$defs/agentType"},
        "input": {"type": "object", "minProperties": 1, "maxProperties": 100},
        "session_id": {"$ref": "#/$defs/uuid"},
        "retrieval_query": {"type": "string", "minLength": 2, "maxLength": 2000},
        "evidence_ids": {"type": "array", "maxItems": 100, "uniqueItems": true, "items": {"$ref": "#/$defs/uuid"}},
        "max_evidence_items": {"type": "integer", "minimum": 1, "maximum": 20},
        "max_cost_usd": {"type": "number", "minimum": 0.001, "maximum": 5}
      }
    },
    "evidenceCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "source_locator"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/uuid"},
        "source_locator": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestion_id", "run_id", "tenant_id", "actor_id", "agent_type", "status", "confidence", "evidence", "output", "provider", "model", "usage", "cost_usd", "cost_status", "cached", "mutation_performed", "created_at"],
      "properties": {
        "suggestion_id": {"$ref": "#/$defs/uuid"},
        "run_id": {"$ref": "#/$defs/uuid"},
        "tenant_id": {"$ref": "#/$defs/uuid"},
        "actor_id": {"$ref": "#/$defs/uuid"},
        "agent_type": {"$ref": "#/$defs/agentType"},
        "status": {"const": "PENDING_REVIEW"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/$defs/evidenceCitation"}},
        "output": {"type": "object"},
        "provider": {"enum": ["llama", "openai"]},
        "model": {"type": "string", "minLength": 1, "maxLength": 500},
        "usage": {"$ref": "#/$defs/tokenUsage"},
        "cost_usd": {"type": ["number", "string", "null"]},
        "cost_status": {"enum": ["priced", "unpriced"]},
        "cached": {"type": "boolean"},
        "cache_source_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "mutation_performed": {"const": false},
        "created_at": {"type": "string", "format": "date-time"},
        "review_decision": {"enum": ["approve", "reject"]},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "providerAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_request_id", "request_sha256", "response_sha256", "latency_ms"],
      "properties": {
        "provider_request_id": {"type": ["string", "null"], "maxLength": 500},
        "request_sha256": {"$ref": "#/$defs/sha256"},
        "response_sha256": {"$ref": "#/$defs/sha256"},
        "latency_ms": {"type": "integer", "minimum": 0}
      }
    },
    "agentRunResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "suggestion", "provider_audit"],
      "properties": {
        "run_id": {"$ref": "#/$defs/uuid"},
        "suggestion": {"$ref": "#/$defs/suggestion"},
        "provider_audit": {"$ref": "#/$defs/providerAudit"}
      }
    },
    "retrievalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query"],
      "not": {"required": ["limit", "page_size"]},
      "properties": {
        "query": {"type": "string", "minLength": 2, "maxLength": 2000},
        "limit": {"type": "integer", "minimum": 1, "maximum": 20},
        "page_size": {"type": "integer", "minimum": 1, "maximum": 20}
      }
    },
    "retrievedKnowledge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "document_id", "source_locator", "media_type", "classification", "snippet", "relevance", "confidence", "indexed_at", "security_flags", "content_sha256", "retrieval_mode", "lexical_relevance", "vector_relevance", "embedding_model"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/uuid"},
        "document_id": {"$ref": "#/$defs/uuid"},
        "source_locator": {"type": "string", "minLength": 1, "maxLength": 2000},
        "media_type": {"type": "string", "minLength": 1, "maxLength": 200},
        "classification": {"$ref": "#/$defs/classification"},
        "snippet": {"type": "string", "maxLength": 2000},
        "relevance": {"type": "number", "minimum": -1, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "indexed_at": {"type": "string", "format": "date-time"},
        "security_flags": {"type": "array", "maxItems": 20, "items": {"type": "string", "maxLength": 200}},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "retrieval_mode": {"enum": ["lexical", "hybrid"]},
        "lexical_relevance": {"type": "number", "minimum": 0, "maximum": 1},
        "vector_relevance": {"type": ["number", "null"], "minimum": -1, "maximum": 1},
        "embedding_model": {"type": ["string", "null"], "maxLength": 500}
      }
    },
    "retrievalResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "query_sha256", "permission_trimmed"],
      "properties": {
        "items": {"type": "array", "maxItems": 20, "items": {"$ref": "#/$defs/retrievedKnowledge"}},
        "query_sha256": {"$ref": "#/$defs/sha256"},
        "permission_trimmed": {"const": true},
        "embedding_usage": {"anyOf": [{"$ref": "#/$defs/tokenUsage"}, {"type": "null"}]},
        "embedding_model": {"type": ["string", "null"], "maxLength": 500}
      }
    },
    "documentImportRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["media_type", "content_base64"],
      "properties": {
        "document_id": {"$ref": "#/$defs/uuid"},
        "source_locator": {"type": "string", "minLength": 1, "maxLength": 240},
        "filename": {"type": "string", "minLength": 1, "maxLength": 240, "pattern": "^[^/\\\\]+$"},
        "media_type": {"enum": ["application/csv", "application/json", "application/pdf", "application/xml", "application/yaml", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "image/svg+xml", "text/csv", "text/markdown", "text/plain", "text/vnd.mermaid", "text/xml", "text/yaml"]},
        "content_base64": {"type": "string", "minLength": 4, "maxLength": 6990508, "contentEncoding": "base64"},
        "classification": {"$ref": "#/$defs/classification"},
        "source_acl": {"$ref": "#/$defs/publicSourceAcl"}
      },
      "oneOf": [
        {"required": ["filename"], "not": {"required": ["source_locator"]}},
        {"required": ["source_locator"], "not": {"required": ["filename"]}}
      ]
    },
    "documentImportReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["import_id", "document_id", "status", "chunks_indexed", "chunks_quarantined", "evidence_ids", "media_type", "content_sha256", "parser", "imported_at", "model_invoked", "classification", "source_acl"],
      "properties": {
        "import_id": {"$ref": "#/$defs/uuid"},
        "document_id": {"$ref": "#/$defs/uuid"},
        "status": {"enum": ["INDEXED", "QUARANTINED"]},
        "chunks_indexed": {"type": "integer", "minimum": 0},
        "chunks_quarantined": {"type": "integer", "minimum": 0},
        "evidence_ids": {"type": "array", "maxItems": 1000, "items": {"$ref": "#/$defs/uuid"}},
        "media_type": {"type": "string", "minLength": 1, "maxLength": 200},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "parser": {"type": "string", "minLength": 1, "maxLength": 200},
        "imported_at": {"type": "string", "format": "date-time"},
        "embedding_usage": {"anyOf": [{"$ref": "#/$defs/tokenUsage"}, {"type": "null"}]},
        "embedding_model": {"type": ["string", "null"], "maxLength": 500},
        "model_invoked": {"const": false},
        "classification": {"$ref": "#/$defs/classification"},
        "source_acl": {"$ref": "#/$defs/publicSourceAcl"}
      }
    },
    "suggestionList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {"type": "array", "maxItems": 100, "items": {"$ref": "#/$defs/suggestion"}}
      }
    },
    "reviewRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision"],
      "properties": {
        "decision": {"enum": ["approve", "reject"]},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "reviewReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "suggestion_id", "reviewer_id", "decision", "suggestion_status", "mutation_performed", "reviewed_at"],
      "properties": {
        "review_id": {"$ref": "#/$defs/uuid"},
        "suggestion_id": {"$ref": "#/$defs/uuid"},
        "reviewer_id": {"$ref": "#/$defs/uuid"},
        "decision": {"enum": ["approve", "reject"]},
        "suggestion_status": {"const": "PENDING_REVIEW"},
        "mutation_performed": {"const": false},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "validated_memory_id": {"anyOf": [{"$ref": "#/$defs/uuid"}, {"type": "null"}]},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "learningOutcomeRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestion_id", "validation", "outcome_type", "outcome", "evidence_ids", "observed_at"],
      "properties": {
        "suggestion_id": {"$ref": "#/$defs/uuid"},
        "validation": {"enum": ["confirmed", "corrected"]},
        "outcome_type": {"type": "string", "minLength": 1, "maxLength": 100, "pattern": "^[a-z][a-z0-9_.-]{0,99}$"},
        "outcome": {"type": "object", "minProperties": 1, "maxProperties": 100},
        "evidence_ids": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"$ref": "#/$defs/uuid"}},
        "observed_at": {"type": "string", "format": "date-time"},
        "note": {"type": "string", "minLength": 1, "maxLength": 2000}
      }
    },
    "learningOutcomeReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memory_id", "suggestion_id", "status", "validation", "reviewer_id", "evidence_ids", "persisted_at", "graph_mutation_performed", "simulation_mutation_performed"],
      "properties": {
        "memory_id": {"$ref": "#/$defs/uuid"},
        "suggestion_id": {"$ref": "#/$defs/uuid"},
        "status": {"const": "VALIDATED"},
        "validation": {"enum": ["confirmed", "corrected"]},
        "reviewer_id": {"$ref": "#/$defs/uuid"},
        "evidence_ids": {"type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": {"$ref": "#/$defs/uuid"}},
        "persisted_at": {"type": "string", "format": "date-time"},
        "graph_mutation_performed": {"const": false},
        "simulation_mutation_performed": {"const": false}
      }
    }
  }
}
