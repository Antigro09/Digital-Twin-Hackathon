{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/schemas/workflow-definition.schema.json",
  "title": "Durable Workflow Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "version", "status", "horizon", "owner", "purpose", "input_schema", "output_schema", "states", "initial_state", "terminal_states", "transitions", "idempotency", "timeouts", "retry", "cancellation", "authorization", "audit"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^workflow\\.[a-z0-9_.-]+$"},
    "version": {"$ref": "#/$defs/semver"},
    "status": {"enum": ["committed", "provisional", "research", "rejected"]},
    "horizon": {"enum": ["H1", "H2", "H3", "H4", "H5"]},
    "owner": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "input_schema": {"type": "object"},
    "output_schema": {"type": "object"},
    "states": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
    "initial_state": {"type": "string"},
    "terminal_states": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "event", "to", "guard", "side_effect"],
        "properties": {
          "from": {"type": "string"},
          "event": {"type": "string", "minLength": 1},
          "to": {"type": "string"},
          "guard": {"type": "string", "minLength": 1},
          "side_effect": {"type": "string"}
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_source", "payload_binding", "replay_result"],
      "properties": {
        "key_source": {"type": "string", "minLength": 1},
        "payload_binding": {"const": "rfc8785_sha256"},
        "replay_result": {"enum": ["original_receipt", "conflict", "no_op"]}
      }
    },
    "timeouts": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "integer", "minimum": 1}},
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_attempts", "initial_interval_seconds", "maximum_interval_seconds", "non_retryable_errors"],
      "properties": {
        "maximum_attempts": {"type": "integer", "minimum": 1},
        "initial_interval_seconds": {"type": "integer", "minimum": 1},
        "maximum_interval_seconds": {"type": "integer", "minimum": 1},
        "non_retryable_errors": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "cancellation": {"type": "object", "required": ["supported", "terminal_behavior"], "properties": {"supported": {"type": "boolean"}, "terminal_behavior": {"type": "string"}}, "additionalProperties": false},
    "authorization": {"type": "object", "required": ["server_derived_tenant", "recheck_before_side_effect"], "properties": {"server_derived_tenant": {"const": true}, "recheck_before_side_effect": {"const": true}}, "additionalProperties": false},
    "audit": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "compatibility": {"type": "string"},
    "deprecated_at": {"type": "string", "format": "date-time"},
    "sunset_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "semver": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"}
  }
}
