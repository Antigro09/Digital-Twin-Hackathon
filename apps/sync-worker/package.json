    "@temporalio/worker": "1.13.2",
    "@temporalio/workflow": "1.13.2",
    "fastify": "5.10.0",
    "neo4j-driver": "6.0.1",
    "pg": "8.16.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "24.7.2",
    "@types/pg": "8.15.5",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
