{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-digital-twin.example/schemas/cli-contract.schema.json",
  "title": "Enterprise Digital Twin CLI Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "version", "horizon", "sdk_contract", "commands", "output", "tenant_context", "idempotency", "timeouts", "rate_limits", "errors", "redaction", "audit", "compatibility"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"const": "cli.edt"},
    "version": {"$ref": "#/$defs/semver"},
    "horizon": {"enum": ["H1", "H2", "H3", "H4"]},
    "sdk_contract": {"type": "string", "minLength": 1},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "operation_id", "risk", "arguments", "exit_codes"],
        "properties": {
          "path": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}},
          "operation_id": {"type": "string", "minLength": 1},
          "risk": {"enum": ["read", "draft", "sensitive_read", "external_mutation", "administration"]},
          "arguments": {"type": "object"},
          "confirmation": {"enum": ["none", "interactive", "exact_payload_approval", "forbidden"]},
          "exit_codes": {"type": "object", "minProperties": 1, "patternProperties": {"^(0|[1-9][0-9]{0,2})$": {"type": "string"}}, "additionalProperties": false}
        }
      }
    },
    "output": {"type": "object", "required": ["default", "machine", "stderr", "pagination"], "properties": {"default": {"enum": ["human_table", "human_text"]}, "machine": {"enum": ["json", "jsonl"]}, "stderr": {"const": "diagnostics_only"}, "pagination": {"enum": ["interactive", "explicit_cursor", "all_with_limit"]}}, "additionalProperties": false},
    "tenant_context": {"type": "object", "required": ["source", "explicit_switch", "reject_tenant_id"], "properties": {"source": {"const": "server_issued_context_handle"}, "explicit_switch": {"const": true}, "reject_tenant_id": {"const": true}}, "additionalProperties": false},
    "idempotency": {"type": "object", "required": ["mutation_key", "automatic_unsafe_retry"], "properties": {"mutation_key": {"const": "required"}, "automatic_unsafe_retry": {"const": false}}, "additionalProperties": false},
    "timeouts": {"type": "object", "required": ["default_seconds", "override_flag"], "properties": {"default_seconds": {"type": "integer", "minimum": 1}, "override_flag": {"const": "--timeout"}}, "additionalProperties": false},
    "rate_limits": {"type": "object", "required": ["honor_retry_after", "report_remaining"], "properties": {"honor_retry_after": {"const": true}, "report_remaining": {"const": true}}, "additionalProperties": false},
    "errors": {"type": "object", "required": ["problem_details", "stable_exit_codes", "trace_id"], "properties": {"problem_details": {"const": "RFC 9457"}, "stable_exit_codes": {"const": true}, "trace_id": {"const": true}}, "additionalProperties": false},
    "redaction": {"type": "object", "required": ["secrets", "response_bodies", "debug_requires_opt_in"], "properties": {"secrets": {"const": true}, "response_bodies": {"const": true}, "debug_requires_opt_in": {"const": true}}, "additionalProperties": false},
    "audit": {"type": "object", "required": ["operation_id", "client_version", "context_handle_hash"], "properties": {"operation_id": {"const": true}, "client_version": {"const": true}, "context_handle_hash": {"const": true}}, "additionalProperties": false},
    "compatibility": {"type": "object", "required": ["semantic_versioning", "deprecation_days", "unknown_fields"], "properties": {"semantic_versioning": {"const": true}, "deprecation_days": {"type": "integer", "minimum": 90}, "unknown_fields": {"const": "ignore_unless_safety_semantic"}}, "additionalProperties": false}
  },
  "$defs": {
    "semver": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"}
  }
}
