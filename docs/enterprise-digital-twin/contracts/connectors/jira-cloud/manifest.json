{
  "schema_version": "1.0",
  "id": "com.enterprise-digital-twin.connector.jira-cloud",
  "version": "1.0.0",
  "publisher": {
    "id": "com.enterprise-digital-twin",
    "display_name": "Enterprise Digital Twin",
    "owning_team": "connector-platform",
    "support_uri": "https://support.enterprise-digital-twin.example/connectors/jira-cloud",
    "security_contact": "security@enterprise-digital-twin.example"
  },
  "provider": "jira",
  "deployment": {
    "supported_variants": ["jira_cloud"],
    "runtime_mode": "network_restricted_connector_worker",
    "oci_image_digest": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
    "minimum_worker_version": "1.0.0",
    "installation_isolation": "tenant_scoped_credentials_queues_cursors_and_egress"
  },
  "auth": {
    "type": "oauth2_authorization_code_confidential",
    "required_permissions": [
      {"name": "read:jira-work", "access": "read"},
      {"name": "read:jira-user", "access": "read"},
      {"name": "write:jira-work", "access": "write"},
      {"name": "manage:jira-webhook", "access": "manage"},
      {"name": "offline_access", "access": "offline"}
    ],
    "forbidden_permissions": ["manage:jira-project", "manage:jira-configuration", "admin", "service-management-write", "granular-scopes"],
    "credential_lifetime_seconds": 3600,
    "refresh_behavior": "single_flight_rotating_refresh_token",
    "secret_storage": "tenant_scoped_envelope_encrypted_reference",
    "effective_grant_policy": "reject_missing_required_or_any_forbidden_permission"
  },
  "capabilities": {
    "reads": [
      {"resource": "accessible_resources", "operations": ["discover", "reconcile", "acl_sync"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /oauth/token/accessible-resources"},
      {"resource": "self", "operations": ["discover", "reconcile", "acl_sync"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-user", "reconciliation_fetch": "GET /rest/api/3/myself"},
      {"resource": "fields", "operations": ["discover", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/field/search"},
      {"resource": "projects", "operations": ["discover", "backfill", "reconcile", "acl_sync"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/project/search"},
      {"resource": "issues", "operations": ["backfill", "incremental", "reconcile", "acl_sync"], "pagination": "ordered_jql", "deletion_behavior": "webhook_then_authenticated_get", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/search/jql"},
      {"resource": "issue_changelog", "operations": ["backfill", "incremental", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/issue/{issueIdOrKey}/changelog"},
      {"resource": "statuses", "operations": ["discover", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/status"},
      {"resource": "versions", "operations": ["backfill", "incremental", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/project/{projectIdOrKey}/version"},
      {"resource": "sprints", "operations": ["backfill", "incremental", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/agile/1.0/board/{boardId}/sprint"},
      {"resource": "comments", "operations": ["backfill", "incremental", "reconcile", "acl_sync"], "pagination": "cursor", "deletion_behavior": "webhook_then_authenticated_get", "required_permission": "read:jira-work", "reconciliation_fetch": "GET /rest/api/3/issue/{issueIdOrKey}/comment"},
      {"resource": "webhooks", "operations": ["discover", "reconcile"], "pagination": "cursor", "deletion_behavior": "scope_check_then_two_scan_confirmation", "required_permission": "manage:jira-webhook", "reconciliation_fetch": "GET /rest/api/3/webhook"}
    ],
    "events": [
      {"event": "jira:issue_created", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "issues"},
      {"event": "jira:issue_updated", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "issues"},
      {"event": "jira:issue_deleted", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "issues"},
      {"event": "comment_created", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "comments"},
      {"event": "comment_updated", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "comments"},
      {"event": "comment_deleted", "delivery_id_source": "X-Atlassian-Webhook-Identifier", "verification_profile": "jira_bearer_path_and_webhook_binding_before_parse", "max_body_bytes": 10485760, "authoritative": false, "reconciliation_resource": "comments"}
    ],
    "mutations": [
      {"command": "jira_issue_remediation_v1", "target_resource": "issue", "operation": "PUT /rest/api/3/issue/{issueIdOrKey}", "default_enabled": false, "approval_class": "two_person_exact_payload_15_minutes", "idempotency_class": "workflow_receipt_provider_verification", "compensation_command": "jira_issue_remediation_restore_v1"}
    ]
  },
  "schemas": {
    "raw_envelope": {"uri": "schemas/raw-envelope.schema.json", "id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/raw-envelope.schema.json", "version": "1.0.0", "sha256": "afcc208df24777ebb17f756d32e38b33e1004733132bf69c40dfc1feef18fb34"},
    "raw_payload": {"uri": "schemas/raw-payload.schema.json", "id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/raw-payload.schema.json", "version": "1.0.0", "sha256": "81f1e7c60b30cc2753e47e818035bc3380287c2b5f65c729dd8faacfec9c3f6b"},
    "normalized_observation": {"uri": "schemas/normalized-observation.schema.json", "id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/normalized-observation.schema.json", "version": "1.0.0", "sha256": "f422be8d24a002360b4913513dc801ccda892a20edc6d17524de77a5b91ebfb3"},
    "cursor": {"uri": "schemas/cursor.schema.json", "id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/cursor.schema.json", "version": "1.0.0", "sha256": "402dba54061893588f8a84e01211745e53664d9e0d71fd5d2d189b9c088d9fd7"},
    "ontology_mapping": {"uri": "schemas/ontology-mapping.schema.json", "id": "https://enterprise-digital-twin.example/connectors/jira-cloud/1.0.0/ontology-mapping.schema.json", "version": "1.0.0", "sha256": "2434b431725101a72c19c7711d73c0322ea5870649c35bd643dbd5c0c196fab2"}
  },
  "rate_limits": {
    "buckets": [{"name": "jira_cloud_api", "limit": 500, "window_seconds": 10}],
    "quota_scope": "cloud_account",
    "max_concurrency_per_installation": 4,
    "tenant_fairness_weight": 1,
    "request_timeout_seconds": 30,
    "retry_classes": ["rate_limit", "provider_5xx", "network_timeout"],
    "backoff": {"minimum_seconds": 1, "maximum_seconds": 300, "jitter": "full", "honor_retry_after": true, "maximum_attempts": 8}
  },
  "cursor": {"schema_ref": "schemas/cursor.schema.json", "commit_granularity": "same_transaction_as_observations_and_outbox", "overlap_seconds": 600, "lookback_days": 180, "reset_modes": ["resume", "rewind_overlap", "authorized_full_reconcile"], "reset_authorization": "connector_admin_and_audited_preview", "last_good_checkpoint": "preserve_until_replacement_commits"},
  "data_policy": {
    "included_fields": ["accessible_resource_and_account_identity", "field_and_project_metadata", "issue_key_type_summary_and_status", "priority_labels_and_due_date", "assignee_and_reporter_references", "parent_subtask_and_issue_links", "sprint_version_and_project_membership", "created_updated_and_bounded_changelog", "comment_metadata_when_enabled", "attachment_metadata_only"],
    "excluded_fields": ["attachment_content", "worklogs", "environment", "development_panel_content", "service_management_content", "admin_configuration", "comment_bodies_when_disabled", "secrets_tokens_and_authorization_headers"],
    "classifications": ["internal", "confidential", "restricted"],
    "raw_retention_class": "connector_raw_h1",
    "normalized_retention_class": "connector_observation_h1",
    "limits": {"max_payload_bytes": 10485760, "max_nesting_depth": 64, "max_string_bytes": 1048576, "max_decompression_ratio": 20, "parse_deadline_seconds": 30},
    "redaction_policy": "secrets_tokens_authorization_headers_and_disallowed_bodies",
    "untrusted_content": true,
    "training_use": "prohibited"
  },
  "network_policy": {
    "rules": [
      {"host": "auth.atlassian.com", "port": 443, "path_prefixes": ["/authorize", "/oauth/token"]},
      {"host": "api.atlassian.com", "port": 443, "path_prefixes": ["/oauth/token/accessible-resources", "/ex/jira/"]}
    ],
    "tls_minimum": "1.2",
    "dns_revalidation": "each_connection_and_redirect",
    "deny_private_link_local_metadata": true,
    "redirect_limit": 0,
    "response_size_limit_bytes": 10485760,
    "connect_deadline_seconds": 5,
    "read_deadline_seconds": 30,
    "manifest_proxy_allowed": false
  },
  "health": {
    "checks": [
      {"type": "credential", "interval_seconds": 300, "timeout_seconds": 10, "failure_threshold": 2, "transition": "suspended", "diagnostic_code": "CONN_JIRA_CREDENTIAL"},
      {"type": "webhook", "interval_seconds": 300, "timeout_seconds": 10, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_JIRA_WEBHOOK"},
      {"type": "freshness", "interval_seconds": 300, "timeout_seconds": 5, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_JIRA_FRESHNESS"},
      {"type": "quota", "interval_seconds": 60, "timeout_seconds": 5, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_JIRA_QUOTA"},
      {"type": "reconciliation", "interval_seconds": 900, "timeout_seconds": 30, "failure_threshold": 3, "transition": "degraded", "diagnostic_code": "CONN_JIRA_RECONCILIATION"}
    ],
    "freshness_slo_seconds": 900,
    "webhook_ack_p95_seconds": 2
  },
  "support": {"compatibility": ">=1.0.0 <2.0.0", "deprecation_state": "active", "sunset_at": null, "owning_service": "connector-worker", "runbook_uri": "https://runbooks.enterprise-digital-twin.example/connectors/jira-cloud", "security_escalation": "security@enterprise-digital-twin.example"}
}
